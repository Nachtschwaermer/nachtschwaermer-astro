---
let seed = 1;
const rand = () => {
	seed = (seed * 9301 + 49297) % 233280;
	return seed / 233280;
};
const stars = Array.from({ length: 70 }, () => ({
	x: rand() * 100,
	y: rand() * 100,
	size: 0.6 + rand() * 1.6,
	delay: rand() * 2,
	dur: 2 + rand() * 3,
	op: 0.25 + rand() * 0.6,
}));
---

<div class="splash-root">
	<div class="splash-bg-radial" id="splash-bg"></div>
	<div class="starfield" id="starfield">
		{
			stars.map((st) => (
				<span
					class="s"
					style={`left: ${st.x}%; top: ${st.y}%; width: ${st.size}px; height: ${st.size}px; box-shadow: 0 0 ${st.size * 2}px rgba(255,255,255,0.4); --op: ${st.op}; --dur: ${st.dur}s; --delay: ${st.delay}s;`}
				/>
			))
		}
	</div>

	<div class="splash-stack">
		<div class="logo-stage" id="logo-stage">
			<div class="moon-glow" id="moon-glow"></div>
			<img class="layer moon" id="moon" src="/images/splash/moon.svg" alt="" />
			<img
				class="layer star1"
				id="star1"
				src="/images/splash/star1.svg"
				alt=""
			/>
			<img
				class="layer star2"
				id="star2"
				src="/images/splash/star2.svg"
				alt=""
			/>
		</div>

		<div class="wordmark-wrap" id="wordmark-wrap">
			<h1 class="wordmark">Nüsser Nachtschwärmer</h1>
			<div class="tagline">
				<span class="tagline-rule"></span>
				<span>seit 1985</span>
				<span class="tagline-rule"></span>
			</div>
		</div>
	</div>
</div>

<style>
	:root {
		--splash-gold: #fdd66b;
		--splash-bg: #0b0912;
	}
	.splash-root {
		position: relative;
		min-height: 100vh;
		min-height: 100dvh;
		width: 100%;
		overflow: hidden;
		color: #e8e4d8;
		background:
			radial-gradient(1200px 800px at 20% 10%, #1a1628 0%, transparent 60%),
			radial-gradient(1000px 700px at 80% 90%, #151026 0%, transparent 60%),
			var(--splash-bg);
		display: flex;
		flex-direction: column;
		align-items: center;
		justify-content: center;
		gap: clamp(16px, 3vmin, 32px);
		padding: 24px 16px;
	}
	.splash-bg-radial {
		position: absolute;
		inset: 0;
		background: radial-gradient(ellipse at 50% 40%, #0e1428 0%, #05070d 80%);
		opacity: 0;
		transition: opacity 600ms ease-out;
		pointer-events: none;
	}
	.splash-bg-radial.is-on {
		opacity: 1;
	}

	.starfield {
		position: absolute;
		inset: 0;
		overflow: hidden;
		opacity: 0;
		transition: opacity 600ms ease-out;
		pointer-events: none;
	}
	.starfield.is-on {
		opacity: 1;
	}
	.starfield .s {
		position: absolute;
		border-radius: 50%;
		background: #fff;
		animation: splash-twinkle var(--dur) ease-in-out var(--delay) infinite;
	}

	@keyframes splash-twinkle {
		0%,
		100% {
			opacity: var(--op, 0.5);
			transform: scale(1);
		}
		50% {
			opacity: 0.1;
			transform: scale(0.6);
		}
	}

	.splash-stack {
		position: relative;
		z-index: 1;
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: clamp(28px, 6vmin, 64px);
		width: 100%;
	}

	.logo-stage {
		position: relative;
		width: clamp(110px, 18vmin, 224px);
		aspect-ratio: 412 / 507;
	}
	.moon-glow {
		position: absolute;
		left: 42.8%;
		top: 50%;
		width: 110%;
		height: 90%;
		transform: translate(-50%, -50%) scale(1);
		border-radius: 50%;
		background: radial-gradient(
			circle,
			rgba(255, 211, 105, 0.22) 0%,
			rgba(255, 211, 105, 0.09) 35%,
			rgba(255, 211, 105, 0) 70%
		);
		opacity: 0;
		pointer-events: none;
		filter: blur(4px);
		will-change: transform, opacity;
	}
	.layer {
		position: absolute;
		transform-origin: 50% 50%;
		opacity: 0;
		will-change: transform, opacity;
	}
	.layer.moon {
		left: -0.13%;
		top: -0.16%;
		width: 85.87%;
		height: 100.22%;
	}
	.layer.star1 {
		left: 42.22%;
		top: 7.41%;
		width: 47.87%;
		height: 42.76%;
	}
	.layer.star2 {
		left: 58.15%;
		top: 51.69%;
		width: 42.14%;
		height: 35.09%;
	}

	.wordmark-wrap {
		text-align: center;
		opacity: 0;
		transform: translateY(8px);
		transition:
			opacity 700ms cubic-bezier(0.33, 1, 0.68, 1),
			transform 700ms cubic-bezier(0.33, 1, 0.68, 1);
		padding: 0 16px;
	}
	.wordmark-wrap.is-on {
		opacity: 1;
		transform: translateY(0);
	}
	.wordmark {
		margin: 0;
		font-family: "Montserrat", system-ui, sans-serif;
		font-size: clamp(20px, 3.5vmin, 32px);
		font-weight: 600;
		letter-spacing: 0.06em;
		text-transform: uppercase;
		color: var(--splash-gold);
		text-shadow:
			0 0 24px rgba(253, 214, 107, 0.35),
			0 1px 0 rgba(0, 0, 0, 0.4);
		line-height: 1.2;
		text-wrap: balance;
	}
	.tagline {
		margin-top: 12px;
		display: flex;
		align-items: center;
		justify-content: center;
		gap: 10px;
		font-size: clamp(10px, 1.4vmin, 12px);
		letter-spacing: 0.28em;
		text-transform: uppercase;
		color: rgba(253, 214, 107, 0.7);
		font-family: "Montserrat", system-ui, sans-serif;
		font-weight: 500;
	}
	.tagline-rule {
		width: 20px;
		height: 1px;
		background: rgba(253, 214, 107, 0.4);
	}

	@media (prefers-reduced-motion: reduce) {
		.layer,
		.moon-glow {
			opacity: 1 !important;
			transform: none !important;
		}
		.starfield .s {
			animation: none;
		}
	}
</style>

<script>
	(function () {
		const moon = document.getElementById("moon") as HTMLElement | null;
		const star1 = document.getElementById("star1") as HTMLElement | null;
		const star2 = document.getElementById("star2") as HTMLElement | null;
		const glow = document.getElementById("moon-glow") as HTMLElement | null;
		const stage = document.getElementById("logo-stage") as HTMLElement | null;
		const bg = document.getElementById("splash-bg") as HTMLElement | null;
		const stars = document.getElementById("starfield") as HTMLElement | null;
		const wordmark = document.getElementById(
			"wordmark-wrap",
		) as HTMLElement | null;

		if (
			!moon ||
			!star1 ||
			!star2 ||
			!glow ||
			!stage ||
			!bg ||
			!stars ||
			!wordmark
		)
			return;

		const prefersReduced = window.matchMedia(
			"(prefers-reduced-motion: reduce)",
		).matches;
		if (prefersReduced) {
			[moon, star1, star2].forEach((el) => {
				el.style.opacity = "1";
				el.style.transform = "translate(0,0) scale(1) rotate(0deg)";
			});
			glow.style.opacity = "0.9";
			glow.style.transform = "translate(-50%, -42%) scale(1)";
			bg.classList.add("is-on");
			stars.classList.add("is-on");
			wordmark.classList.add("is-on");
			return;
		}

		const easeOutCubic = (t: number) => 1 - Math.pow(1 - t, 3);
		const easeOutQuint = (t: number) => 1 - Math.pow(1 - t, 5);
		const easeOutBack = (t: number, s = 1.35) =>
			1 + (s + 1) * Math.pow(t - 1, 3) + s * Math.pow(t - 1, 2);
		const easeOutQuart = (t: number) => 1 - Math.pow(1 - t, 4);
		const win = (now: number, start: number, dur: number) =>
			Math.max(0, Math.min(1, (now - start) / dur));
		const lerp = (a: number, b: number, t: number) => a + (b - a) * t;

		const REF_SIZE = 260;

		const start = performance.now();
		requestAnimationFrame(() => {
			bg.classList.add("is-on");
			stars.classList.add("is-on");
		});
		setTimeout(() => wordmark.classList.add("is-on"), 1400);

		function frame(now: number) {
			const t = now - start;
			const loopT = t / 1000;
			const k = stage!.offsetWidth / REF_SIZE;

			const moonT = win(t, 200, 1200);
			const me = easeOutQuint(moonT);
			const mx = lerp(-70, 0, me);
			const my = lerp(140, 0, me) - Math.sin(me * Math.PI) * 18;
			const mScale = lerp(0.55, 1, easeOutBack(moonT, 1.1));
			const mRot = lerp(-10, 0, easeOutCubic(moonT));
			const bobY = Math.sin(loopT * 1.3) * 3;
			const bobRot = Math.sin(loopT * 0.8) * 0.8;
			const mOp = easeOutCubic(win(t, 150, 500));
			moon!.style.transform = `translate(${mx * k}px, ${(my + bobY) * k}px) scale(${mScale}) rotate(${mRot + bobRot}deg)`;
			moon!.style.opacity = String(mOp);

			const s1T = win(t, 650, 900);
			const s1e = easeOutBack(s1T, 1.6);
			const s1x = lerp(60, 0, s1e);
			const s1y = lerp(-90, 0, s1e);
			const s1Scale = lerp(0.3, 1, easeOutBack(s1T, 1.8));
			const s1Rot =
				lerp(40, 0, easeOutQuart(s1T)) + Math.sin(loopT * 1.6 + 1) * 2;
			const s1Op = easeOutCubic(win(t, 650, 400));
			star1!.style.transform = `translate(${s1x * k}px, ${s1y * k}px) scale(${s1Scale}) rotate(${s1Rot}deg)`;
			star1!.style.opacity = String(s1Op);

			const s2T = win(t, 850, 900);
			const s2e = easeOutBack(s2T, 1.4);
			const s2x = lerp(80, 0, s2e);
			const s2y = lerp(-50, 0, s2e);
			const s2Scale = lerp(0.3, 1, easeOutBack(s2T, 1.8));
			const s2Rot =
				lerp(-30, 0, easeOutQuart(s2T)) + Math.sin(loopT * 1.2 + 3) * 2.5;
			const s2Op = easeOutCubic(win(t, 850, 400));
			star2!.style.transform = `translate(${s2x * k}px, ${s2y * k}px) scale(${s2Scale}) rotate(${s2Rot}deg)`;
			star2!.style.opacity = String(s2Op);

			const glowPulse = 1 + Math.sin(loopT * 1.1) * 0.03;
			const glowOpacity = easeOutCubic(win(t, 200, 900)) * 0.9;
			glow!.style.transform = `translate(-50%, -42%) scale(${glowPulse})`;
			glow!.style.opacity = String(glowOpacity);

			requestAnimationFrame(frame);
		}
		requestAnimationFrame(frame);
	})();
</script>
