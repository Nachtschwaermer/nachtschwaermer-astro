---
import { Picture } from "astro:assets";
import flagge from "../assets/flagge_zeichnung.png";

interface Props {
	numbers: {
		label: string;
		value: number | string;
	}[];
}
const { numbers } = Astro.props as Props;
---

<section class="my-20 jarallax">
	<Picture
		src={flagge}
		layout="full-width"
		formats={["avif", "webp"]}
		alt=""
		class="absolute top-0 left-0 w-full h-full object-cover object-center jarallax-img"
	/>
	<div class="bg-gray-800/60 text-white">
		<ul class="container mx-auto grid md:grid-cols-3 gap-6 py-16">
			{
				numbers.map((number) => (
					<li class="text-center">
						<span class="block text-8xl mb-6 font-slab">{number.value}</span>
						<span class="block tracking-wide font-light">{number.label}</span>
					</li>
				))
			}
		</ul>
	</div>
</section>
