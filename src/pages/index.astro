---
import { Picture } from "astro:assets";
import Layout from "../layouts/Layout.astro";
import MemberRoster from "../components/MemberRoster.astro";
import Quote from "../components/Quote.astro";
import Remembrance from "../components/Remembrance.astro";
import Statistics from "../components/Statistics.astro";
import zugZeichnung from "../assets/zug_zeichnung.png";

import { frontmatter as about } from "../pages/_about.md";
import { Content as AboutContent } from "../pages/_about.md";
import { getCollection } from "astro:content";

const persons = (await getCollection("persons")).sort((a, b) =>
	a.id.localeCompare(b.id),
);
const deceased = (await getCollection("deceased")).sort((a, b) =>
	a.id.localeCompare(b.id),
);
---

<Layout title="Nüsser Nachtschwärmer">
	<main>
		<section
			class="container mx-auto my-20 px-6 flex flex-col md:flex-row space-y-4 md:space-y-0 md:space-x-24 items-start"
		>
			<div class="md:pt-2 md:w-1/4">
				<h2
					class="uppercase text-sm tracking-wide border-b border-gold font-title"
				>
					{about.title}
				</h2>
			</div>
			<div class="prose prose-invert lg:prose-lg w-full md:w-3/4">
				<Picture
					src={zugZeichnung}
					layout="full-width"
					formats={["avif", "webp"]}
					alt="Illustration des Zuges der Nüsser Nachtschwärmer"
					class="not-prose w-full mb-10"
				/>
				<AboutContent />
			</div>
		</section>
		<Statistics numbers={about.statistics} />
		<MemberRoster persons={persons} />
		<Remembrance deceased={deceased} />
		<Quote text={about.quote.text} cite={about.quote.cite} />
	</main>
</Layout>
